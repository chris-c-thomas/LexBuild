# Data API environment variables
# Copy to .env.local for local development overrides.

# HTTP server port
API_PORT=4322

# SQLite content database (rebuilt by `lexbuild ingest`)
# Default: <monorepo-root>/lexbuild.db (auto-detected)
LEXBUILD_DB_PATH=

# SQLite API keys database (persists across re-ingestion)
# Default: <monorepo-root>/lexbuild-keys.db (auto-detected)
LEXBUILD_KEYS_DB_PATH=

# Meilisearch connection (standard port: 7700, Docker dev: 7711)
MEILI_URL=http://127.0.0.1:7700
MEILI_SEARCH_KEY=
MEILI_MASTER_KEY=
