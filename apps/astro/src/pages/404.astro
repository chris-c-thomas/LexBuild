---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Not Found" description="Page not found.">
  <div class="flex flex-col items-center justify-center py-24 text-center">
    <h1 class="text-6xl font-bold text-muted-foreground/50">404</h1>
    <p class="mt-4 text-lg text-muted-foreground">Page not found.</p>
    <a
      href="/"
      class="mt-6 text-sm font-medium text-slate-blue-600 hover:text-slate-blue-700 dark:text-slate-blue-400 dark:hover:text-slate-blue-300 transition-colors"
    >
      Back to home
    </a>
  </div>
</BaseLayout>
