---
import { getPrevNext } from "@/lib/docs-nav";

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const { prev, next } = getPrevNext(slug);
---

{
  (prev || next) && (
    <nav class="mt-12 flex gap-4" aria-label="Pagination">
      {prev ? (
        <a
          href={`/docs/${prev.slug}`}
          class="flex-1 rounded-sm border border-border bg-white p-4 transition-colors hover:border-slate-blue-400 dark:bg-card dark:hover:border-slate-blue-600">
          <span class="text-xs text-muted-foreground">Previous</span>
          <span class="mt-1 block text-sm font-medium text-foreground">&larr; {prev.title}</span>
        </a>
      ) : (
        <div class="flex-1" />
      )}
      {next ? (
        <a
          href={`/docs/${next.slug}`}
          class="flex-1 rounded-sm border border-border bg-white p-4 text-right transition-colors hover:border-slate-blue-400 dark:bg-card dark:hover:border-slate-blue-600">
          <span class="text-xs text-muted-foreground">Next</span>
          <span class="mt-1 block text-sm font-medium text-foreground">{next.title} &rarr;</span>
        </a>
      ) : (
        <div class="flex-1" />
      )}
    </nav>
  )
}
