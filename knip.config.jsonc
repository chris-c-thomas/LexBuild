{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "workspaces": {
    "packages/*": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"],
    },
    "apps/astro": {
      "entry": [
        "src/pages/**/*.astro",
        "src/env.d.ts",
        "astro.config.ts",
        "scripts/*.ts",
      ],
      "project": ["src/**/*.{ts,tsx,astro}", "scripts/*.ts"],
    },
  },
  "ignoreDependencies": [
    "prettier-plugin-astro",
    "prettier-plugin-tailwindcss",
  ],
}
